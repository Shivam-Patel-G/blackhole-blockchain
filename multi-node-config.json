{
  "network_config": {
    "name": "blackhole-testnet",
    "bootstrap_nodes": [
      {
        "id": "node1",
        "p2p_port": 3000,
        "api_port": 8080,
        "role": "bootstrap"
      }
    ],
    "nodes": [
      {
        "id": "node1",
        "p2p_port": 3000,
        "api_port": 8080,
        "role": "bootstrap",
        "connect_to": []
      },
      {
        "id": "node2", 
        "p2p_port": 3001,
        "api_port": 8081,
        "role": "validator",
        "connect_to": ["node1"]
      },
      {
        "id": "node3",
        "p2p_port": 3002,
        "api_port": 8082,
        "role": "validator", 
        "connect_to": ["node1", "node2"]
      },
      {
        "id": "node4",
        "p2p_port": 3003,
        "api_port": 8083,
        "role": "validator",
        "connect_to": ["node1", "node3"]
      },
      {
        "id": "node5",
        "p2p_port": 3004,
        "api_port": 8084,
        "role": "validator",
        "connect_to": ["node2", "node4"]
      },
      {
        "id": "node6",
        "p2p_port": 3005,
        "api_port": 8085,
        "role": "validator",
        "connect_to": ["node3", "node5"]
      },
      {
        "id": "node7",
        "p2p_port": 3006,
        "api_port": 8086,
        "role": "validator",
        "connect_to": ["node4", "node6"]
      },
      {
        "id": "node8",
        "p2p_port": 3007,
        "api_port": 8087,
        "role": "validator",
        "connect_to": ["node5", "node7"]
      },
      {
        "id": "node9",
        "p2p_port": 3008,
        "api_port": 8088,
        "role": "validator",
        "connect_to": ["node6", "node8"]
      },
      {
        "id": "node10",
        "p2p_port": 3009,
        "api_port": 8089,
        "role": "validator",
        "connect_to": ["node7", "node9"]
      }
    ]
  },
  "test_scenarios": {
    "transaction_propagation": {
      "description": "Test transaction propagation across all nodes",
      "submit_node": "node1",
      "verify_nodes": ["node2", "node3", "node4", "node5", "node6", "node7", "node8", "node9", "node10"],
      "timeout_seconds": 30,
      "expected_result": "transaction appears in pending pool of all nodes"
    },
    "block_synchronization": {
      "description": "Test block synchronization across network",
      "mining_node": "auto",
      "verify_nodes": "all",
      "timeout_seconds": 60,
      "expected_result": "all nodes have same block height"
    },
    "consensus_verification": {
      "description": "Test consensus mechanism with new validator",
      "action_node": "node5",
      "verify_nodes": "all",
      "timeout_seconds": 30,
      "expected_result": "new validator appears on all nodes"
    },
    "network_partition": {
      "description": "Test network resilience during partition",
      "partition_node": "node3",
      "partition_duration_seconds": 30,
      "recovery_timeout_seconds": 45,
      "expected_result": "partitioned node catches up after recovery"
    },
    "load_testing": {
      "description": "Test network under transaction load",
      "concurrent_transactions": 10,
      "nodes_involved": ["node1", "node2", "node3", "node4", "node5"],
      "timeout_seconds": 120,
      "expected_result": "all transactions processed successfully"
    }
  },
  "success_criteria": {
    "transaction_propagation_time": "< 30 seconds",
    "block_synchronization_time": "< 60 seconds", 
    "consensus_agreement": "100% of nodes agree",
    "partition_recovery_time": "< 45 seconds",
    "load_test_success_rate": "> 95%"
  }
}
